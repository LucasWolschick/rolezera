<main class="vertical container">
  <%= link_to "Voltar", home_path, class: "anchor" %>

  <h1>Chamar rolê</h1>

  <p>Que tipo de rolê você está a fim?</p>

  <%= form_with url: "/events/topic", method: :post, class: "vertical center-contents" do |form| %>
    <ul class="radio-list">
      <% @topics.each do |topic| %>
        <li>
          <label class="radio-button">
            <%= form.radio_button :event_topic, topic.key, class: "hidden-radio", checked: @draft.event_topic&.key == topic.key %>
            <span><%= topic.description %></span>
          </label>
        </li>
      <% end %>
    </ul>

    <%= form.submit "Continuar", class: "button" %>
  <% end %>
</main>